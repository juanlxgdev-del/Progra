class Persona:
    def __init__(self, id, nombre, email, tel):
        self.id = id
        self.nombre = nombre
        self.email = email
        self.telefono = tel

    def login(self):
        print(f"\n- Sesion iniciada: {self.nombre} -")

    def logout(self):
        print(f"- Sesion cerrada: {self.nombre} -")

class Usuario(Persona):
    def __init__(self, id, nombre, email, tel):
        super().__init__(id, nombre, email, tel)
        self.puntosFidelidad = 0
        self.reservas = []

    def crearReserva(self, funcion, cantidad):
        libres = funcion.sala.obtenerLibres()
        if cantidad > libres:
            return None
        asientos = funcion.sala.asignarAsientos(cantidad)
        precio = funcion.precio * cantidad
        reserva = Reserva(len(self.reservas) + 1, self, funcion, asientos, precio)
        self.reservas.append(reserva)
        self.puntosFidelidad += int(precio / 10)
        return reserva

